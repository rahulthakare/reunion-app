// ─────────────────────────────────────────────────────────────────
// Firebase Storage Security Rules — apply via Firebase Console
// (Build → Storage → Rules) OR via the Firebase CLI.
//
// Strategy:
//   - Anyone can READ images (gallery, articles, fun-zone are public)
//   - Authenticated users can WRITE to their own folders
//   - The actual admin-only checks happen in the Next.js API routes
//     (which run server-side with the Admin SDK and verify the
//     session cookie before allowing photo metadata to be saved).
//
// This is "defense in depth": even if a malicious user bypassed the
// API and wrote a file directly to Storage, they would have nothing
// to point to it from Firestore — orphaned files cause no real harm.
// ─────────────────────────────────────────────────────────────────

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Public read for everything (so MemoryGallery + ArticleCard
    // can serve images without an auth token).
    match /{allPaths=**} {
      allow read: if true;
    }

    // Photo gallery — admin-only writes (enforced server-side too)
    match /gallery/{path=**} {
      allow write: if request.auth != null;
    }

    // Articles — admin-only writes (enforced server-side too)
    match /articles/{path=**} {
      allow write: if request.auth != null;
    }

    // Fun Zone — any authenticated batchmate can upload
    // (Guess Who?, Caption This!, Then & Now)
    match /fun-zone/{path=**} {
      allow write: if request.auth != null;
    }
  }
}
